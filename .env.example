# GitHub Trending 自动化系统 - 环境配置

# ===== 数据库配置 =====
# 数据库类型：sqlite, postgresql, mysql
DB_TYPE=sqlite

# SQLite 配置（DB_TYPE=sqlite 时使用）
SQLITE_DB_PATH=github_trending.db

# PostgreSQL 配置（DB_TYPE=postgresql 时使用）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=github_trending

# MySQL 配置（DB_TYPE=mysql 时使用）
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=github_trending

# ===== 网络配置 =====
# GitHub 代理（可选，国内服务器建议配置）
# 格式：http://username:password@proxy_host:proxy_port
# GITHUB_PROXY=http://127.0.0.1:7890

# 爬取超时时间（秒）
CRAWL_TIMEOUT=30

# ===== 日志配置 =====
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
